<script>
// ========== STATE ==========
const DB = {
  customers: [],
  items: [],
  orders: [],
  orderItems: [],
  orderCounter: 1
};
 
// Default credentials
const CREDENTIALS = { username: 'admin', password: 'admin123' };
 
// ========== LOGIN ==========
function doLogin() {
  const u = document.getElementById('username').value.trim();
  const p = document.getElementById('password').value;
  const err = document.getElementById('login-error');
 
  if (u === CREDENTIALS.username && p === CREDENTIALS.password) {
    err.style.display = 'none';
    document.getElementById('login-page').style.display = 'none';
    document.getElementById('app').style.display = 'block';
    const displayName = u.charAt(0).toUpperCase() + u.slice(1);
    document.getElementById('logged-user').textContent = displayName;
    document.getElementById('dropdown-name').textContent = displayName;
    updateStats();
    initOrderId();
    setDefaultDate();
  } else {
    err.style.display = 'block';
    err.style.animation = 'none';
    setTimeout(() => err.style.animation = '', 10);
  }
}
 
function toggleDropdown() {
  const btn = document.getElementById('user-btn');
  const dd = document.getElementById('user-dropdown');
  btn.classList.toggle('open');
  dd.classList.toggle('open');
}
 
function closeDropdown() {
  document.getElementById('user-btn').classList.remove('open');
  document.getElementById('user-dropdown').classList.remove('open');
}
 
// Close dropdown when clicking outside
document.addEventListener('click', function(e) {
  const wrapper = document.querySelector('.user-wrapper');
  if (wrapper && !wrapper.contains(e.target)) closeDropdown();
});
 
function doLogout() {
  closeDropdown();
  if (confirm('Are you sure you want to logout?')) {
    document.getElementById('app').style.display = 'none';
    document.getElementById('login-page').style.display = 'flex';
    document.getElementById('username').value = '';
    document.getElementById('password').value = '';
  }
}
 
// Login on Enter
document.getElementById('password').addEventListener('keydown', e => { if (e.key === 'Enter') doLogin(); });
document.getElementById('username').addEventListener('keydown', e => { if (e.key === 'Enter') document.getElementById('password').focus(); });
 
// ========== NAVIGATION ==========
function showSection(name, btn) {
  document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
  document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('section-' + name).classList.add('active');
  if (btn) btn.classList.add('active');
  if (name === 'dashboard') updateStats();
}
 
// ========== TOAST ==========
function showToast(msg, type = '') {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.className = 'toast show ' + type;
  setTimeout(() => t.className = 'toast', 2800);
}
 
// ========== DASHBOARD ==========
function updateStats() {
  document.getElementById('stat-customers').textContent = DB.customers.length;
  document.getElementById('stat-items').textContent = DB.items.length;
  document.getElementById('stat-orders').textContent = DB.orders.length;
}
 
// ========== CUSTOMER MANAGEMENT ==========
function saveCustomer() {
  const id = document.getElementById('cust-id').value.trim();
  const name = document.getElementById('cust-name').value.trim();
  const addr = document.getElementById('cust-address').value.trim();
  const salary = document.getElementById('cust-salary').value;
 
  if (!id || !name) { showToast('Customer ID and Name are required', 'error'); return; }
  if (DB.customers.find(c => c.id === id)) { showToast('Customer ID already exists!', 'error'); return; }
 
  DB.customers.push({ id, name, addr, salary });
  renderCustomers(DB.customers);
  resetCustomer();
  showToast('✅ Customer saved!', 'success');
}
 
function updateCustomer() {
  const id = document.getElementById('cust-id').value.trim();
  const idx = DB.customers.findIndex(c => c.id === id);
  if (idx === -1) { showToast('Customer not found!', 'error'); return; }
  DB.customers[idx] = {
    id,
    name: document.getElementById('cust-name').value.trim(),
    addr: document.getElementById('cust-address').value.trim(),
    salary: document.getElementById('cust-salary').value
  };
  renderCustomers(DB.customers);
  resetCustomer();
  showToast('✅ Customer updated!', 'success');
}
 
function deleteCustomer() {
  const id = document.getElementById('cust-id').value.trim();
  const idx = DB.customers.findIndex(c => c.id === id);
  if (idx === -1) { showToast('Customer not found!', 'error'); return; }
  if (!confirm('Delete this customer?')) return;
  DB.customers.splice(idx, 1);
  renderCustomers(DB.customers);
  resetCustomer();
  showToast('🗑️ Customer deleted!');
}
 
function resetCustomer() {
  ['cust-id','cust-name','cust-address','cust-salary'].forEach(id => document.getElementById(id).value = '');
}
 
function filterCustomers() {
  const q = document.getElementById('cust-search').value.toLowerCase();
  renderCustomers(DB.customers.filter(c =>
    c.id.toLowerCase().includes(q) || c.name.toLowerCase().includes(q) || c.addr.toLowerCase().includes(q)
  ));
}
 
function renderCustomers(list) {
  const tbody = document.getElementById('cust-tbody');
  if (!list.length) {
    tbody.innerHTML = '<tr class="empty-row"><td colspan="4">No customers found</td></tr>';
    return;
  }
  tbody.innerHTML = list.map(c => `
    <tr onclick="selectCustomer('${c.id}')">
      <td>${c.id}</td><td>${c.name}</td><td>${c.addr}</td><td>$${parseFloat(c.salary||0).toFixed(2)}</td>
    </tr>`).join('');
}
 
function selectCustomer(id) {
  const c = DB.customers.find(c => c.id === id);
  if (!c) return;
  document.getElementById('cust-id').value = c.id;
  document.getElementById('cust-name').value = c.name;
  document.getElementById('cust-address').value = c.addr;
  document.getElementById('cust-salary').value = c.salary;
}
 
// ========== ITEM MANAGEMENT ==========
function saveItem() {
  const code = document.getElementById('item-code').value.trim();
  const name = document.getElementById('item-name').value.trim();
  const price = document.getElementById('item-price').value;
  const qty = document.getElementById('item-qty').value;
 
  if (!code || !name) { showToast('Item Code and Name are required', 'error'); return; }
  if (DB.items.find(i => i.code === code)) { showToast('Item Code already exists!', 'error'); return; }
 
  DB.items.push({ code, name, price: parseFloat(price||0), qty: parseInt(qty||0) });
  renderItems(DB.items);
  resetItem();
  showToast('✅ Item saved!', 'success');
}
 
function updateItem() {
  const code = document.getElementById('item-code').value.trim();
  const idx = DB.items.findIndex(i => i.code === code);
  if (idx === -1) { showToast('Item not found!', 'error'); return; }
  DB.items[idx] = {
    code,
    name: document.getElementById('item-name').value.trim(),
    price: parseFloat(document.getElementById('item-price').value||0),
    qty: parseInt(document.getElementById('item-qty').value||0)
  };
  renderItems(DB.items);
  resetItem();
  showToast('✅ Item updated!', 'success');
}
 
function deleteItem() {
  const code = document.getElementById('item-code').value.trim();
  const idx = DB.items.findIndex(i => i.code === code);
  if (idx === -1) { showToast('Item not found!', 'error'); return; }
  if (!confirm('Delete this item?')) return;
  DB.items.splice(idx, 1);
  renderItems(DB.items);
  resetItem();
  showToast('🗑️ Item deleted!');
}
 
function resetItem() {
  ['item-code','item-name','item-price','item-qty'].forEach(id => document.getElementById(id).value = '');
}
 
function filterItems() {
  const q = document.getElementById('item-search').value.toLowerCase();
  renderItems(DB.items.filter(i =>
    i.code.toLowerCase().includes(q) || i.name.toLowerCase().includes(q)
  ));
}
 
function renderItems(list) {
  const tbody = document.getElementById('item-tbody');
  if (!list.length) {
    tbody.innerHTML = '<tr class="empty-row"><td colspan="4">No items found</td></tr>';
    return;
  }
  tbody.innerHTML = list.map(i => `
    <tr onclick="selectItem('${i.code}')">
      <td>${i.code}</td><td>${i.name}</td><td>$${i.price.toFixed(2)}</td><td>${i.qty}</td>
    </tr>`).join('');
}
 
function selectItem(code) {
  const i = DB.items.find(i => i.code === code);
  if (!i) return;
  document.getElementById('item-code').value = i.code;
  document.getElementById('item-name').value = i.name;
  document.getElementById('item-price').value = i.price;
  document.getElementById('item-qty').value = i.qty;
}
 
// ========== ORDER MANAGEMENT ==========
function initOrderId() {
  document.getElementById('ord-id').value = 'ORD' + String(DB.orderCounter).padStart(3,'0');
}
 
function setDefaultDate() {
  document.getElementById('ord-date').value = new Date().toISOString().split('T')[0];
}
 
document.addEventListener('DOMContentLoaded', () => {
  renderCustomers([]);
  renderItems([]);
  renderOrderItems();
});
 
// Auto-fill customer info from Customer ID
document.getElementById && (function(){
  setTimeout(() => {
    document.getElementById('ord-cust-id').addEventListener('input', function() {
      const c = DB.customers.find(c => c.id === this.value.trim());
      if (c) {
        document.getElementById('ord-cust').value = c.name;
        document.getElementById('ord-name').value = c.name;
        document.getElementById('ord-salary').value = '$' + parseFloat(c.salary||0).toFixed(2);
        document.getElementById('ord-address').value = c.addr;
      }
    });
    document.getElementById('ord-item-code').addEventListener('input', function() {
      const it = DB.items.find(i => i.code === this.value.trim());
      if (it) {
        document.getElementById('ord-item').value = it.name;
        document.getElementById('ord-item-name').value = it.name;
        document.getElementById('ord-item-price').value = it.price.toFixed(2);
        document.getElementById('ord-item-qtyh').value = it.qty;
      }
    });
  }, 500);
})();
 
function autoFillItem() {
  const name = document.getElementById('ord-item').value.trim().toLowerCase();
  const it = DB.items.find(i => i.name.toLowerCase().includes(name));
  if (it) {
    document.getElementById('ord-item-code').value = it.code;
    document.getElementById('ord-item-name').value = it.name;
    document.getElementById('ord-item-price').value = it.price.toFixed(2);
    document.getElementById('ord-item-qtyh').value = it.qty;
  }
}
 
function addOrderItem() {
  const code = document.getElementById('ord-item-code').value.trim();
  const name = document.getElementById('ord-item-name').value.trim();
  const price = parseFloat(document.getElementById('ord-item-price').value || 0);
  const qty = parseInt(document.getElementById('ord-order-qty').value || 0);
  const stock = parseInt(document.getElementById('ord-item-qtyh').value || 0);
 
  if (!code || !name) { showToast('Select an item first!', 'error'); return; }
  if (qty <= 0) { showToast('Enter valid quantity!', 'error'); return; }
  if (qty > stock) { showToast('Insufficient stock!', 'error'); return; }
 
  const existing = DB.orderItems.find(o => o.code === code);
  if (existing) {
    existing.qty += qty;
    existing.total = existing.price * existing.qty;
  } else {
    DB.orderItems.push({ code, name, price, qty, total: price * qty });
  }
 
  // Reduce stock
  const it = DB.items.find(i => i.code === code);
  if (it) it.qty -= qty;
 
  renderOrderItems();
  calcTotal();
 
  // Reset item fields
  ['ord-item','ord-item-code','ord-item-name','ord-item-price','ord-item-qtyh','ord-order-qty'].forEach(id =>
    document.getElementById(id).value = '');
  showToast('✅ Item added!', 'success');
}
 
function renderOrderItems() {
  const tbody = document.getElementById('order-tbody');
  if (!DB.orderItems.length) {
    tbody.innerHTML = '<tr class="empty-row"><td colspan="5">No items added</td></tr>';
    return;
  }
  tbody.innerHTML = DB.orderItems.map((o,i) => `
    <tr>
      <td>${o.code}</td>
      <td>${o.name}</td>
      <td>$${o.price.toFixed(2)}</td>
      <td>${o.qty}</td>
      <td>$${o.total.toFixed(2)}</td>
    </tr>`).join('');
}
 
function calcTotal() {
  const total = DB.orderItems.reduce((s, o) => s + o.total, 0);
  document.getElementById('ord-total').value = '$' + total.toFixed(2);
  calcBalance();
}
 
function calcBalance() {
  const total = DB.orderItems.reduce((s, o) => s + o.total, 0);
  const disc = parseFloat(document.getElementById('ord-discount').value || 0);
  const sub = total - (total * disc / 100);
  document.getElementById('ord-subtotal').value = '$' + sub.toFixed(2);
  const cash = parseFloat(document.getElementById('ord-cash').value || 0);
  const balance = cash - sub;
  document.getElementById('ord-balance').value = '$' + balance.toFixed(2);
}
 
function completePurchase() {
  if (!DB.orderItems.length) { showToast('Add items first!', 'error'); return; }
  const custId = document.getElementById('ord-cust-id').value;
  if (!custId) { showToast('Select a customer!', 'error'); return; }
  const cash = parseFloat(document.getElementById('ord-cash').value || 0);
  const sub = parseFloat(document.getElementById('ord-subtotal').value.replace('$','') || 0);
  if (cash < sub) { showToast('Insufficient cash!', 'error'); return; }
 
  DB.orders.push({
    id: document.getElementById('ord-id').value,
    date: document.getElementById('ord-date').value,
    custId,
    items: [...DB.orderItems],
    total: sub
  });
 
  DB.orderCounter++;
  DB.orderItems = [];
  renderOrderItems();
  initOrderId();
  setDefaultDate();
  ['ord-cust','ord-cust-id','ord-name','ord-salary','ord-address',
   'ord-total','ord-subtotal','ord-cash','ord-discount','ord-balance'].forEach(id =>
    document.getElementById(id).value = '');
  updateStats();
  showToast('🎉 Purchase complete!', 'success');
}
 
