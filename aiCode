<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Grocery Store POS System</title>
  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet"/>

  <!-- ── Stylesheet (View layer) ── -->
  <link rel="stylesheet" href="css/style.css"/>
</head>
<body>

<!-- ═══════════════════════════════════════════════════════════
     VIEW — Login Page
     ═══════════════════════════════════════════════════════════ -->
<div id="login-page">
  <div class="login-left">
    <svg class="cart-svg" viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M30 50 L50 50 L70 140 L170 140 L190 70 L60 70" stroke="#5dca3c" stroke-width="10" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
      <circle cx="90"  cy="158" r="13" stroke="#5dca3c" stroke-width="8" fill="none"/>
      <circle cx="155" cy="158" r="13" stroke="#5dca3c" stroke-width="8" fill="none"/>
      <rect x="95" y="30" width="50" height="40" rx="4" stroke="#5dca3c" stroke-width="7" fill="none"/>
      <line x1="120" y1="30" x2="120" y2="70" stroke="#5dca3c" stroke-width="6"/>
      <path d="M108 30 C108 20 120 22 120 30" stroke="#5dca3c" stroke-width="6" fill="none" stroke-linecap="round"/>
      <path d="M132 30 C132 20 120 22 120 30" stroke="#5dca3c" stroke-width="6" fill="none" stroke-linecap="round"/>
      <line x1="78"  y1="95" x2="78"  y2="130" stroke="#5dca3c" stroke-width="8" stroke-linecap="round"/>
      <line x1="105" y1="95" x2="105" y2="130" stroke="#5dca3c" stroke-width="8" stroke-linecap="round"/>
      <line x1="132" y1="95" x2="132" y2="130" stroke="#5dca3c" stroke-width="8" stroke-linecap="round"/>
    </svg>
    <div class="brand-name">Grocery Store</div>
  </div>

  <div class="login-right">
    <h1>Welcome to Grocery Store<br/>POS System</h1>
    <div class="login-form">
      <div class="form-group">
        <label>Username</label>
        <input type="text" id="username" placeholder="Enter username" autocomplete="off"/>
      </div>
      <div class="form-group">
        <label>Password</label>
        <input type="password" id="password" placeholder="Enter password"/>
      </div>
      <div class="login-error" id="login-error"> Invalid username or password</div>
      <button class="btn-login" onclick="AppController.login()">Login</button>
    </div>
  </div>
</div>


<div id="app">

  <!-- Navigation -->
  <nav>
    <button class="nav-btn active" onclick="AppController.showSection('dashboard', this)">Dashboard</button>
    <button class="nav-btn"        onclick="AppController.showSection('customer',  this)">Customer Management</button>
    <button class="nav-btn"        onclick="AppController.showSection('item',      this)">Item Management</button>
    <button class="nav-btn"        onclick="AppController.showSection('order',     this)">Order Management</button>
    <div class="nav-spacer"></div>

    <!-- User dropdown -->
    <div class="user-wrapper">
      <button class="user-btn" id="user-btn" onclick="AppController.toggleDropdown()">
        <div class="user-avatar">👤</div>
        <span id="logged-user">Admin</span>
        <span class="dropdown-arrow">▼</span>
      </button>
      <div class="user-dropdown" id="user-dropdown">
        <div class="dropdown-header">
          <div class="dh-name" id="dropdown-name">Admin</div>
          <div class="dh-role">Store Admin</div>
        </div>
        <button class="dropdown-item logout" onclick="AppController.logout()">🚪 &nbsp;Logout</button>
      </div>
    </div>
  </nav>

  <!-- Main content area -->
  <div class="main-content">

    <!-- ── Dashboard ── -->
    <div class="section active" id="section-dashboard">
      <div class="stats-grid">
        <div class="stat-card">
          <div class="stat-icon">👥</div>
          <div class="stat-num" id="stat-customers">0</div>
          <div class="stat-label">Customers</div>
        </div>
        <div class="stat-card">
          <div class="stat-icon">🛍️</div>
          <div class="stat-num" id="stat-items">0</div>
          <div class="stat-label">Items</div>
        </div>
        <div class="stat-card">
          <div class="stat-icon">📋</div>
          <div class="stat-num" id="stat-orders">0</div>
          <div class="stat-label">Orders</div>
        </div>
      </div>
    </div>

    <!-- ── Customer Management ── -->
    <div class="section" id="section-customer">
      <h2 class="section-title">Customer Management</h2>
      <div class="mgmt-layout">

        <!-- Form (View) — actions call CustomerController -->
        <div class="mgmt-form">
          <label>Customer ID</label>
          <input type="text"   id="cust-id"  placeholder="C001"/>
          <label>Customer Name</label>
          <input type="text"   id="cust-name" placeholder="Full Name"/>
          <label>Customer Address</label>
          <input type="text"   id="cust-address" placeholder="Address"/>
          <label>Customer Salary</label>
          <input type="number" id="cust-salary"  placeholder="0.00"/>
          <div class="btn-row">
            <button class="btn btn-save"  onclick="CustomerController.save()">Save</button>
            <button class="btn btn-update" onclick="CustomerController.update()">Update</button>
          </div>
          <div class="btn-row">
            <button class="btn btn-delete" onclick="CustomerController.remove()">Delete</button>
            <button class="btn btn-reset"  onclick="CustomerController.reset()">Reset</button>
          </div>
        </div>

        <!-- Table panel (View) -->
        <div class="table-panel">
          <div class="search-row">
            <div class="search-input-wrap">
              <span>🔍</span>
              <input class="search-input" id="cust-search" type="text" placeholder="Search..."
                     oninput="CustomerController.search()"/>
            </div>
            <button class="btn btn-search" onclick="CustomerController.search()">Search</button>
          </div>
          <table class="data-table">
            <thead>
              <tr>
                <th>Customer ID</th>
                <th>Customer Name</th>
                <th>Address</th>
                <th>Salary</th>
              </tr>
            </thead>
            <tbody id="cust-tbody"></tbody>
          </table>
        </div>

      </div>
    </div>

    <!-- ── Item Management ── -->
    <div class="section" id="section-item">
      <h2 class="section-title">Item Management</h2>
      <div class="mgmt-layout">

        <div class="mgmt-form">
          <label>Item Code</label>
          <input type="text"   id="item-code"  placeholder="IT001"/>
          <label>Item Name</label>
          <input type="text"   id="item-name"  placeholder="Product Name"/>
          <label>Item Price</label>
          <input type="number" id="item-price" placeholder="0.00"/>
          <label>Item Qty</label>
          <input type="number" id="item-qty"   placeholder="0"/>
          <div class="btn-row">
            <button class="btn btn-save"   onclick="ItemController.save()">Save</button>
            <button class="btn btn-update" onclick="ItemController.update()">Update</button>
          </div>
          <div class="btn-row">
            <button class="btn btn-delete" onclick="ItemController.remove()">Delete</button>
            <button class="btn btn-reset"  onclick="ItemController.reset()">Reset</button>
          </div>
        </div>

        <div class="table-panel">
          <div class="search-row">
            <div class="search-input-wrap">
              <span>🔍</span>
              <input class="search-input" id="item-search" type="text" placeholder="Search..."
                     oninput="ItemController.search()"/>
            </div>
            <button class="btn btn-search" onclick="ItemController.search()">Search</button>
          </div>
          <table class="data-table">
            <thead>
              <tr>
                <th>Item Code</th>
                <th>Item Name</th>
                <th>Item Price</th>
                <th>Qty</th>
              </tr>
            </thead>
            <tbody id="item-tbody"></tbody>
          </table>
        </div>

      </div>
    </div>

    <!-- ── Order Management ── -->
    <div class="section" id="section-order">
      <h2 class="section-title">Order Management</h2>
      <div class="order-top">

        <!-- Invoice Details -->
        <div class="order-panel">
          <h3>Invoice Details</h3>
          <div class="order-field">
            <label>Order Id</label>
            <input type="text" id="ord-id"      placeholder="ORD001" readonly/>
            <label>Date</label>
            <input type="date" id="ord-date"/>
            <label>Customer</label>
            <input type="text" id="ord-cust"    placeholder="Name"/>
            <label>Customer ID</label>
            <input type="text" id="ord-cust-id" placeholder="C001"/>
            <label>Name</label>
            <input type="text" id="ord-name"    placeholder="Name" readonly/>
            <label>Salary</label>
            <input type="text" id="ord-salary"  placeholder="0.00" readonly/>
            <label>Address</label>
            <input type="text" id="ord-address" placeholder="Address" readonly/>
          </div>
        </div>

        <!-- Item Select -->
        <div class="order-panel">
          <h3>Item Select</h3>
          <div class="order-field">
            <label>Item</label>
            <input type="text"   id="ord-item"       placeholder="Name"/>
            <label>Item Code</label>
            <input type="text"   id="ord-item-code"  placeholder="IT001"/>
            <label>Item Name</label>
            <input type="text"   id="ord-item-name"  placeholder="Auto-fill" readonly/>
            <label>Price</label>
            <input type="number" id="ord-item-price" placeholder="0.00" readonly/>
            <label>Item QtyH</label>
            <input type="number" id="ord-item-qtyh"  placeholder="0" readonly/>
            <label>Order Qty</label>
            <input type="number" id="ord-order-qty"  placeholder="1"/>
          </div>
          <button class="btn-add-item" onclick="OrderController.addItem()">Add Item</button>
        </div>

        <!-- Summary -->
        <div class="order-panel">
          <h3>Summary</h3>
          <div class="summary-row">
            <label>Total</label>
            <input type="text" id="ord-total"    placeholder="0.00" readonly/>
          </div>
          <div class="summary-row">
            <label>Subtotal</label>
            <input type="text" id="ord-subtotal" placeholder="0.00" readonly/>
          </div>
          
          <div class="summary-row">
            <label>Cash</label>
            <input type="number" id="ord-cash" placeholder="Cash" />
          </div>
          <div class="summary-row">
            <label>Discount</label>
            <input type="number" id="ord-discount" placeholder="Discount%" />
          </div>
          <!-- <div class="half-row" style="margin-bottom:8px">
            <input type="number" id="ord-cash"     placeholder="Cash"/>
            <input type="number" id="ord-discount" placeholder="Discount%"/>
          </div>
          <div style="font-size:0.78rem;color:var(--text-mid);margin-bottom:4px;text-align:center">
            Cash &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; Discount
          </div> -->
          <div class="summary-row">
            <label>Balance</label>
            <input type="text" id="ord-balance" placeholder="0.00" readonly/>
          </div>
          <button class="btn-purchase" onclick="OrderController.completePurchase()">🛒 Purchase</button>
        </div>

      </div>

      <!-- Cart table -->
      <div class="order-table-panel">
        <table class="data-table">
          <thead>
            <tr>
              <th>Item Code</th>
              <th>Item Name</th>
              <th>Item Price</th>
              <th>Item Qty</th>
              <th>Total</th>
            </tr>
          </thead>
          <tbody id="order-tbody"></tbody>
        </table>
      </div>
    </div>

  </div><!-- /main-content -->
</div><!-- /app -->

<!-- Toast notification -->
<div class="toast" id="toast"></div>


<!-- DTOs -->
<script src="DTO/Customer.js"></script>
<script src="DTO/Item.js"></script>
<script src="DTO/order.js"></script>

<!-- Models -->
<script src="model/CustomerModel.js"></script>
<script src="model/ItemModel.js"></script>
<script src="model/OrderModel.js"></script>

<!-- Controllers -->
<script src="controller/CustomerController.js"></script>
<script src="controller/ItemController.js"></script>
<script src="controller/OrderController.js"></script>

<!-- DB bootstrap -->
<script src="db/database.js"></script>

<script>


/** Show a toast notification */
function showToast(msg, type = '') {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.className = 'toast show ' + type;
  setTimeout(() => t.className = 'toast', 2800);
}

/** Refresh dashboard stat counters */
function updateStats() {
  document.getElementById('stat-customers').textContent = CustomerModel.count();
  document.getElementById('stat-items').textContent     = ItemModel.count();
  document.getElementById('stat-orders').textContent    = OrderModel.count();
}

/* ===================================================================
   AppController — authentication & navigation
   =================================================================== */
const AppController = (() => {

  const CREDENTIALS = { username: 'admin', password: 'admin123' };

  /* ── Auth ───────────────────────────────────────────────── */

  function login() {
    const u   = document.getElementById('username').value.trim();
    const p   = document.getElementById('password').value;
    const err = document.getElementById('login-error');

    if (u === CREDENTIALS.username && p === CREDENTIALS.password) {
      err.style.display = 'none';
      document.getElementById('login-page').style.display = 'none';
      document.getElementById('app').style.display        = 'block';

      const display = u.charAt(0).toUpperCase() + u.slice(1);
      document.getElementById('logged-user').textContent  = display;
      document.getElementById('dropdown-name').textContent = display;

      // Bootstrap models & controllers
      Database.init();
    } else {
      err.style.display = 'block';
    }
  }

  function logout() {
    closeDropdown();
    if (!confirm('Are you sure you want to logout?')) return;
    document.getElementById('app').style.display        = 'none';
    document.getElementById('login-page').style.display = 'flex';
    document.getElementById('username').value = '';
    document.getElementById('password').value = '';
  }

  /* ── Navigation ─────────────────────────────────────────── */

  function showSection(name, btn) {
    document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
    document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
    document.getElementById('section-' + name).classList.add('active');
    if (btn) btn.classList.add('active');
    if (name === 'dashboard') updateStats();
  }

  /* ── User dropdown ──────────────────────────────────────── */

  function toggleDropdown() {
    document.getElementById('user-btn').classList.toggle('open');
    document.getElementById('user-dropdown').classList.toggle('open');
  }

  function closeDropdown() {
    document.getElementById('user-btn').classList.remove('open');
    document.getElementById('user-dropdown').classList.remove('open');
  }

  /* ── Global keyboard shortcuts ──────────────────────────── */
  document.addEventListener('keydown', e => {
    if (e.target.id === 'password' && e.key === 'Enter') login();
    if (e.target.id === 'username'  && e.key === 'Enter') document.getElementById('password').focus();
  });

  // Close dropdown when clicking outside
  document.addEventListener('click', e => {
    const wrapper = document.querySelector('.user-wrapper');
    if (wrapper && !wrapper.contains(e.target)) closeDropdown();
  });

  return { login, logout, showSection, toggleDropdown, closeDropdown };
})();
</script>

</body>
</html>